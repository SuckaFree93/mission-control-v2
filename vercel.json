{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_APP_NAME": "Mission Control v2",
      "NEXT_PUBLIC_APP_VERSION": "2.1.0",
      "NEXT_PUBLIC_ENABLE_REALTIME": "true"
    }
  },
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "regions": ["iad1"]
}